# Atlas shared configuration (development example)
# Copy to apps/<service>/.env or monorepo root .env and adjust values.

APP_ENV=development
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=debug

MONGODB_URI=mongodb://localhost:27017/atlas
REDIS_URL=redis://localhost:6379

# Minimum 32 characters in development; minimum 64 in production.
JWT_SECRET=dev-secret-which-is-at-least-32-chars

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
WORKER_CONCURRENCY=5
ENABLE_DEBUG=true

# Optional AI providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
