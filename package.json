{
  "name": "project-atlas",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "10.9.1"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "axios": "^1.18.1",
    "bullmq": "^5.79.3",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.4",
    "pino": "^10.3.1",
    "redis": "^6.1.0",
    "tsx": "^4.23.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  }
}
